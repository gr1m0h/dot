#!/usr/bin/env bash
# Rebuild Ghostty-Nvim.app whenever the source AppleScript template changes.
# hash: {{ include "dot_local/share/chezmoi-scripts/Ghostty-Nvim.applescript.tmpl" | sha256sum }}

set -euo pipefail

# Skip in CI or non-macOS environments.
if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ] || [ "$(uname)" != "Darwin" ]; then
    echo "Skipping Ghostty-Nvim.app setup (CI or non-macOS)"
    exit 0
fi

APPLESCRIPT="${HOME}/.local/share/chezmoi-scripts/Ghostty-Nvim.applescript"
BUILD_SCRIPT="{{ .chezmoi.sourceDir }}/../scripts/applescript/ghostty-nvim/build-ghostty-nvim-app.sh"

if [ ! -x "$BUILD_SCRIPT" ]; then
    # Fall back to invoking via bash in case the bit isn't set yet.
    bash "$BUILD_SCRIPT" "$APPLESCRIPT"
else
    "$BUILD_SCRIPT" "$APPLESCRIPT"
fi
