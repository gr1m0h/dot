{
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_MICROCOMPACT": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:8",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "CLAUDE_CODE_ENABLE_COST_TRACKING": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "ECC_HOOK_PROFILE": "standard",
    "CLAUDE_CODE_ENABLE_WORKTREE_ISOLATION": "1",
    "CLAUDE_CODE_MAX_SUBAGENT_DEPTH": "3"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(make *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(ruby *)",
      "Bash(bundle *)",
      "Bash(rake *)",
      "Bash(rails *)",
      "Bash(rspec *)",
      "Bash(php *)",
      "Bash(composer *)",
      "Bash(artisan *)",
      "Bash(phpunit *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Read(src/**)",
      "Read(lib/**)",
      "Read(app/**)",
      "Read(tests/**)",
      "Read(test/**)",
      "Read(spec/**)",
      "Read(docs/**)",
      "Read(internal/**)",
      "Read(cmd/**)",
      "Read(pkg/**)",
      "Read(config/**)",
      "Read(scripts/**)",
      "Read(.github/**)",
      "Read(*.md)",
      "Read(*.json)",
      "Read(*.yaml)",
      "Read(*.yml)",
      "Edit(src/**)",
      "Edit(lib/**)",
      "Edit(app/**)",
      "Edit(tests/**)",
      "Edit(test/**)",
      "Edit(internal/**)",
      "Edit(cmd/**)",
      "Edit(pkg/**)",
      "Edit(spec/**)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(*> /etc/*)",
      "Bash(*| sh)",
      "Bash(*| bash)",
      "Bash(*| zsh)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.env)",
      "Read(secrets/**)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*password*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(package-lock.json)",
      "Edit(yarn.lock)",
      "Edit(pnpm-lock.yaml)",
      "Edit(bun.lockb)",
      "Edit(*.lock)",
      "Edit(vendor/**)",
      "Bash(*pickle.loads*)",
      "Bash(*yaml.load*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git push --force-with-lease *)",
      "Bash(gh pr create *)",
      "Bash(npm publish *)",
      "Bash(docker *)",
      "Bash(pip install *)",
      "Bash(cargo add *)",
      "Bash(go get *)",
      "Bash(bundle install *)",
      "Bash(composer require *)",
      "Bash(gem install *)",
      "Edit(package.json)",
      "Edit(tsconfig.json)",
      "Edit(Gemfile)",
      "Edit(composer.json)",
      "Edit(go.mod)",
      "Edit(Gemfile.lock)",
      "Edit(composer.lock)",
      "Edit(*.config.*)",
      "Write(**/*.sql)",
      "Write(**/*.sh)"
    ],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/session-start.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/session-end.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/session-end.js",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/pre-tool-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/pre-tool-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write $CLAUDE_FILE_PATH 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/ssrf-guard.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/post-tool-verify.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/architecture-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/test-runner.js",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/cost-monitor.js",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/telemetry-collector.js",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/circuit-breaker.js",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/prompt-validator.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/pre-compact-protector.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/subagent-monitor.js",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/subagent-monitor.js",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/on-failure-recover.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/circuit-breaker.js"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/quality-gate.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME\"/.claude/hooks/task-validator.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage@latest statusline"
  },
  "language": "japanese",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "git",
      "gh",
      "docker"
    ]
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable",
  "plansDirectory": "./.claude/plans",
  "teammateMode": "in-process"
}
